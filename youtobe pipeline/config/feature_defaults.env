# 管线「质量向」功能默认全开（不含任何 API 密钥）。
# run.py / finish_outputs.py / translate_srt.py / dub_zh.py 会在加载用户 .env 前读入本文件（override=False），
# 用户可在 .env 或系统环境中用同名变量覆盖为 0/off。

YOUTOBE_TRANSLATION_HYBRID=1
YOUTOBE_TRANSLATE_READING_ALIGN=1
YOUTOBE_TRANSLATE_READING_CPS=3.45
YOUTOBE_TRANSLATE_READING_OVER_RATIO=1.05
YOUTOBE_TRANSLATE_READING_UNDER_RATIO=0.82
YOUTOBE_TRANSLATE_READING_MIN_UNDER_SLOT=0.72
YOUTOBE_READING_UNITS_TTS_BIAS=1.04
YOUTOBE_TRANSLATE_READING_ALIGN_PASSES=3
YOUTOBE_TRANSLATE_READING_ALIGN_CHUNK=12

YOUTOBE_DUB_EMOTION_ALIGN=1
YOUTOBE_DUB_READING_OVER_CHUNK=10
YOUTOBE_DUB_READING_UNDER_CHUNK=12
# TTS 润色批大小（条数越小越稳；批量条数不一致时自动逐条重试）
# YOUTOBE_DUB_TTS_POLISH_CHUNK=8

# 配音时间轴：去重叠；超长槽在「单条 cue 内」拆多段 TTS（不增加字幕条数）
YOUTOBE_DUB_FIX_OVERLAP=1
YOUTOBE_DUB_MAX_SLOT_MS=11000
# 单 cue 内每段口播的最小时长（毫秒），过小易被 TTS 裁切；过大则少拆段
YOUTOBE_DUB_MIN_SUBPIECE_MS=400
YOUTOBE_DUB_OVERLAP_GAP_MS=48

# 硬烧字幕 + 双语合并（burn_subtitles / merge_bilingual_srt）
BURN_SUBTITLE_MARGINV=18
BILINGUAL_MAX_EN_CHARS=80
BILINGUAL_MAX_ZH_CHARS=40

# Edge：无代理时压低并发，减轻 NoAudioReceived（有代理时仍可用 --dub-concurrency 5+）
YOUTOBE_EDGE_TTS_UNPROXIED_CONCURRENCY=2
