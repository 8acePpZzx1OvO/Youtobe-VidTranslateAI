# 复制为 .env 后填写。smart 模式（默认开启「机翻+大模型润色」混合，见 YOUTOBE_TRANSLATION_HYBRID）：
# 大模型+DeepL 混合 > 大模型+Azure 混合 > 仅 DeepL > 仅 Azure > 仅 DeepSeek > 大模型(OpenAI兼容) > 阿里云 > 腾讯云 > Google > MyMemory
#
# 非密钥的「质量向」默认：config/feature_defaults.env（run.py / translate_srt / dub_zh / finish_outputs 会先加载，
# 再加载本 .env；本文件中的同名变量可覆盖 feature_defaults）。

# --- DeepL ---
DEEPL_API_KEY=
# DEEPL_USE_PRO=0

# --- Azure Translator ---
MICROSOFT_API_KEY=
AZURE_TRANSLATOR_REGION=

# --- 国内 / 通用 OpenAI 兼容 Chat（推荐：硅基流动、通义兼容模式等；未配置时可仅用 DeepSeek）---
# 文档: https://docs.siliconflow.cn/ 等；BASE_URL 通常以 /v1 结尾；模型名以控制台为准
YOUTOBE_LLM_API_KEY=
# YOUTOBE_LLM_BASE_URL=https://api.siliconflow.cn/v1
# 默认主模型（各子任务可用 YOUTOBE_LLM_*_MODEL 覆盖，见 translation_clients.py）
# YOUTOBE_LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
# YOUTOBE_LLM_TRANSLATION_MODEL=
# YOUTOBE_LLM_REFINE_MODEL=
# YOUTOBE_LLM_FLUENT_MODEL=
# YOUTOBE_LLM_COLLOQUIAL_MODEL=
# YOUTOBE_LLM_TTS_POLISH_MODEL=
# YOUTOBE_LLM_DUB_DURATION_MODEL=
# 英译中主批次的采样温度（略高更口语，默认约 0.32；见 translation_clients）
# YOUTOBE_LLM_TRANSLATION_TEMP=0.32

# --- DeepSeek（OpenAI 兼容 API；可与 DeepL 或 Azure 搭配混合翻译）---
DEEPSEEK_API_KEY=
# 官方默认可填 https://api.deepseek.com ；自建/代理时改成你的 base（勿带 /v1 结尾也可）
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# 主翻译 / 润色模型（例如 deepseek-chat；若你的控制台提供 deepseek-v4-flash 则填该名）
# DEEPSEEK_TRANSLATION_MODEL=deepseek-chat
# DeepSeek 英译中批次温度（默认约 0.36；略高更自然口语）
# DEEPSEEK_TRANSLATION_TEMP=0.36
# 第二遍润色可单独指定（不设则同 DEEPSEEK_TRANSLATION_MODEL）
# DEEPSEEK_REFINE_MODEL=
# --speech-smooth 时顺化模型（不设则同 DEEPSEEK_TRANSLATION_MODEL）
# DEEPSEEK_FLUENT_MODEL=
# 设为 0 时：有机翻 Key 也不再与大模型混合润色，仅走单一后端优先级
# YOUTOBE_TRANSLATION_HYBRID=1

# --- 翻译后「中文朗读时长 ↔ 英文字幕槽位」对齐（translate_srt；需大模型 Key；见 subtitle_reading_time.py）---
# YOUTOBE_TRANSLATE_READING_ALIGN=1
# YOUTOBE_TRANSLATE_READING_CPS=3.45
# 预估朗读/槽位 > 该比值 → over（压缩），默认约 1.05 略紧以减轻吞字
# YOUTOBE_TRANSLATE_READING_OVER_RATIO=1.05
# 预估/槽位 < 该比值且槽位够长 → under（略充实），默认约 0.82 以减少句内干等
# YOUTOBE_TRANSLATE_READING_UNDER_RATIO=0.82
# 槽位秒数低于此值不做 under（短句不硬灌水）
# YOUTOBE_TRANSLATE_READING_MIN_UNDER_SLOT=0.72
# 判定 over/under 时把中文负载乘以该系数（>1 略保守，多触发压缩）
# YOUTOBE_READING_UNITS_TTS_BIAS=1.04
# 朗读对齐大模型扫描最多轮数（每轮重扫 over/under）
# YOUTOBE_TRANSLATE_READING_ALIGN_PASSES=3
# YOUTOBE_TRANSLATE_READING_ALIGN_CHUNK=12
# YOUTOBE_LLM_READING_ALIGN_MODEL=

# --- OpenAI（仅兼容旧 .env；新环境优先 YOUTOBE_LLM_* 或 DEEPSEEK_*）---
OPENAI_API_KEY=
# OPENAI_TRANSLATION_MODEL=gpt-4o-mini
# 口语顺化（translate_srt.py --speech-smooth）专用模型，不设则沿用 OPENAI_TRANSLATION_MODEL
# OPENAI_FLUENT_MODEL=gpt-4o-mini
# 配音口语化（dub_zh.py --colloquial-openai）专用模型
# OPENAI_COLLOQUIAL_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# --- 阿里云机器翻译（通用版 TranslateGeneral）---
ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=
# 兼容旧变量名（可选）
# ALIYUN_ACCESS_KEY_ID=
# ALIYUN_ACCESS_KEY_SECRET=
# 地域，默认 cn-hangzhou
ALIYUN_MT_REGION=cn-hangzhou
# ALIYUN_MT_CONCURRENCY=6

# --- 腾讯云文本翻译 TMT（TextTranslate）---
TENCENTCLOUD_SECRET_ID=
TENCENTCLOUD_SECRET_KEY=
# 地域，如 ap-beijing、ap-shanghai
TENCENT_TMT_REGION=ap-beijing
# 控制台项目 ID，无则 0
TENCENT_TMT_PROJECT_ID=0
# 并发数（默认 3，接口有 QPS 限制）
# TENCENT_TMT_CONCURRENCY=3

# --- yt-dlp 下载（SSL 断连 / 网络不稳时）---
# 代理，例如 http://127.0.0.1:7890（未设置时也会读取 HTTPS_PROXY）
# YOUTOBE_YTDLP_PROXY=
# YOUTOBE_YTDLP_RETRIES=20
# YOUTOBE_YTDLP_FRAGMENT_RETRIES=20
# YOUTOBE_YTDLP_SOCKET_TIMEOUT=90
# YOUTOBE_YTDLP_SLEEP_REQUESTS=0.5
# 分片并发，1=串行（更稳，默认 1）
# YOUTOBE_YTDLP_CONCURRENT_FRAGMENTS=1
# 排障用：不校验 HTTPS 证书（有风险）
# YOUTOBE_YTDLP_INSECURE_SSL=0

# 成片后再整片观看倍速（1.0=不导出倍速版；与 run.py / finish_outputs --video-speed 一致，不修改 SRT）
# YOUTOBE_VIDEO_SPEED=1.0
# 倍速重编码（可选，见 scripts/apply_video_playback_speed.py）
# YOUTOBE_SPEED_ENCODE_PRESET=fast
# YOUTOBE_SPEED_ENCODE_CRF=23

# --- 输出精简（搬运：raw 仅 mp4；processed 仅 en/zh SRT + 硬烧成片；默认开）---
# YOUTOBE_MINIMIZE_OUTPUTS=1

# --- 配音句尾释放（减轻 TTS 硬切吞音，毫秒）---
# YOUTOBE_DUB_TAIL_GRACE_MS=90
# YOUTOBE_DUB_TAIL_GAP_SAFE_MS=45

# Edge TTS：优先 WebSocket 流式聚合 MP3（见腾讯云社区 Edge TTS 实践）；仍建议国内配代理
# YOUTOBE_EDGE_TTS_PROXY=http://127.0.0.1:7890
# 未走代理时默认把并发压到 2，减轻限流（可用 1–8 覆盖）
# YOUTOBE_EDGE_TTS_UNPROXIED_CONCURRENCY=2
# 重试：每冷却轮内尝试次数 / 冷却轮数（默认 6 / 10）
# YOUTOBE_EDGE_TTS_INNER_TRIES=6
# YOUTOBE_EDGE_TTS_NET_ROUNDS=10
# 仍失败时写短静音占位让成片继续（0=改为直接报错）
# YOUTOBE_EDGE_TTS_FAIL_SILENT=1
# 未设置时也会依次读取 HTTPS_PROXY、HTTP_PROXY、ALL_PROXY

# 硬烧字幕字体（Windows 默认 Microsoft YaHei）
# BURN_SUBTITLE_FONT=Microsoft YaHei
# 底边距：越小越靠近画面底部（默认 18）；字号/描边见 BURN_SUBTITLE_FONTSIZE、BURN_SUBTITLE_OUTLINE
# BURN_SUBTITLE_MARGINV=18
# BURN_SUBTITLE_FONTSIZE=16
# BURN_SUBTITLE_OUTLINE=1

# 双语合并单行上限（字符）；略超仍单行，减少半句碎条（见 merge_bilingual_srt.py）
# BILINGUAL_MAX_EN_CHARS=80
# BILINGUAL_MAX_ZH_CHARS=40

# --- ElevenLabs TTS（可选，与 ai-dubbing 同款 eleven_multilingual_v2）---
# 参考: https://github.com/jin-wook-lee-96/ai-dubbing
# ELEVENLABS_API_KEY=
# 默认女声 Sarah（与上游仓库一致）；也可在控制台选其他 voice id
# ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL

# --- 火山引擎 OpenSpeech 中文配音（run.py / dub_zh.py --backend volc 或 auto）---
# 参考融合: https://github.com/jiayuqi7813/video-Zebra-china
# VOLCENGINE_TTS_API_KEY=
# VOLCENGINE_TTS_RESOURCE_ID=volc.service_type.10029
# 默认中文音色（当 --dub-voice 仍为 Edge 默认时会自动改用此项）
# VOLC_TTS_VOICE=zh_female_qingxin

# --- 配音对齐与 Edge 语速（可选）---
# YOUTOBE_DUB_MAX_SPEEDUP=1.22
# 配音去重叠；超长槽在单条 cue 内拆多段 TTS（不增加字幕条数）
# YOUTOBE_DUB_FIX_OVERLAP=1
# YOUTOBE_DUB_MAX_SLOT_MS=11000
# YOUTOBE_DUB_MIN_SUBPIECE_MS=400
# YOUTOBE_DUB_OVERLAP_GAP_MS=48
# 口播略长于英文字幕槽位时：若 实际时长/槽位 ≤ 该比值则只裁尾、不加速（更自然，默认 1.12）
# YOUTOBE_DUB_TRUNCATE_RATIO=1.12
# 超长句压缩是否用 ffmpeg atempo（1=开，0=退回 pydub speedup）
# YOUTOBE_DUB_FFMPEG_ATEMPO=1
# YOUTOBE_DUB_EDGE_RATE=-5%
# 中文口播 CPS（与 subtitle_reading_time / translate_srt 一致；配音前 over/under 扫描）
# YOUTOBE_DUB_CPS_TARGET=3.45
# 配音前朗读扫描与 translate_srt 共用 subtitle_reading_time（阈值另见 YOUTOBE_TRANSLATE_READING_*）；仅覆盖 CPS 时仍读 over/under 环境变量
# YOUTOBE_DUB_READING_OVER_CHUNK=10
# YOUTOBE_DUB_READING_UNDER_CHUNK=12
# TTS 二次润色模型（dub_zh.py --tts-polish-openai，不设则沿用 OPENAI_COLLOQUIAL_MODEL 或翻译模型）
# OPENAI_TTS_POLISH_MODEL=gpt-4o-mini
# 配音「按英文句长压缩中文」专用模型（不设则沿用口语化/翻译模型）
# OPENAI_DUB_DURATION_FIT_MODEL=gpt-4o-mini

# --- 配音情绪韵律（大模型读英文+中文稿 → Edge 逐条 rate/pitch 或 ElevenLabs stability/similarity）---
# 1=开（默认）；需英文轴 .en.srt 与中文条数对齐；火山 TTS 当前无逐条情感 API，仅打日志提示
# YOUTOBE_DUB_EMOTION_ALIGN=1
# YOUTOBE_DUB_EMOTION_CHUNK=10
# YOUTOBE_DUB_EMOTION_TEMP=0.42
# YOUTOBE_LLM_DUB_EMOTION_MODEL=
# Fish Speech：同一套数值会粗映射为中文稿前的简短风格前缀（与 fish-speech S2 方括号指令一致）

# --- Fish Speech HTTP 中文配音（dub_zh.py --backend fish；或 auto + YOUTOBE_DUB_PREFER_FISH_SPEECH=1）---
# 上游: https://github.com/fishaudio/fish-speech ；本地启动示例:
#   python tools/api_server.py --listen 127.0.0.1:8888
# 依赖见 requirements.txt（ormsgpack 或 msgpack）
# YOUTOBE_FISH_SPEECH_URL=http://127.0.0.1:8888
# 与 api_server --api-key 一致时填写（否则可留空）
# YOUTOBE_FISH_SPEECH_API_KEY=
# 参考音色 ID（不设且 --dub-voice 非 Edge/火山/Eleven 形态时，可把 voice 当作 reference_id）
# YOUTOBE_FISH_SPEECH_REFERENCE_ID=
# YOUTOBE_DUB_PREFER_FISH_SPEECH=0
# 并发上限（默认 2；服务端压力大时勿调高）
# YOUTOBE_FISH_SPEECH_MAX_CONCURRENCY=2

# --- 火山文本翻译（可选，若后续接入 translate_srt --engine volc）---
# VOLCENGINE_ACCESS_KEY=
# VOLCENGINE_SECRET_KEY=
# VOLCENGINE_REGION=cn-north-1
