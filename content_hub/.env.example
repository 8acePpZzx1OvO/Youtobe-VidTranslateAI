# content_hub 发布凭证（复制为 content_hub/.env，勿提交 .env）

# B站创作中心 / 开放平台（Phase 3 实际上传时填写）
BILIBILI_SESSDATA=
BILIBILI_BILI_JCT=
BILIBILI_DEDEUSERID=
# 设为 1 时仅模拟上传，不写平台
CONTENT_HUB_PUBLISH_DRY_RUN=1

# 微信视频号（个人号 API 受限，默认 dry-run；企业号按开放平台文档配置）
WEIXIN_CHANNELS_APP_ID=
WEIXIN_CHANNELS_APP_SECRET=
WEIXIN_CHANNELS_ACCESS_TOKEN=

# 台账库路径（可选，默认 content_hub/data/jobs.db）
# CONTENT_HUB_DB_PATH=
